# Environment variables
# Copy to .env.local for local development. Never commit real secrets.

# Resend — https://resend.com
# Used by POST /api/contact to deliver form submissions.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
CONTACT_TO_EMAIL=

# Database — Prisma
# Local SQLite (default):
DATABASE_URL="file:./prisma/dev.db"
# Production (Turso or Vercel Postgres): replace with your connection string.
# DATABASE_URL=

# GitHub GraphQL API — pinned repositories on /projects
# Create a classic PAT with public_repo (read-only) or fine-grained read access.
GITHUB_TOKEN=
GITHUB_USERNAME=pguntupalli1025
